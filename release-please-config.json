{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-component-in-tag": false,
  "tag-separator": "-",
  "packages": {
    ".": {
      "package-name": "console",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        { "type": "json", "path": "console-electron/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "console-shell/package.json", "jsonpath": "$.version" }
      ]
    }
  }
}
